# Production builds always require Supabase Auth. Use supabase for cloud data.
VITE_DATA_SOURCE=mock
VITE_API_BASE_URL=/api

# Required when VITE_DATA_SOURCE=supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional override. Defaults to the published mapping Google Sheet CSV.
VITE_MAPPING_CLIENTS_CSV_URL=

# Optional override for the authenticated Vercel background-analysis trigger.
VITE_CLIENT_INGESTION_TRIGGER_ENDPOINT=/api/trigger-client-ingestion

# Optional override. Defaults to brand-assets.
VITE_BRAND_ASSETS_BUCKET=brand-assets

# Optional override. Defaults to the Moons n8n hook generation webhook.
VITE_N8N_HOOK_WEBHOOK_URL=

# Optional backend endpoint for selected-hook artwork generation.
# Keep OPENAI_API_KEY on the backend only. Do not expose it as VITE_*.
VITE_ARTWORK_GENERATION_ENDPOINT=

# Optional. Set mode to n8n and provide a browser-accessible webhook to route
# artwork generation through n8n instead of the OpenAI backend endpoint.
VITE_ARTWORK_GENERATION_MODE=openai
VITE_N8N_ARTWORK_WEBHOOK_URL=

# Server/worker only. Do not expose these as VITE_* or use them in browser code.
SUPABASE_URL=
APIFY_TOKEN=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_BRAND_ANALYSIS_MODEL=gpt-5.6-terra
OPENAI_HOOK_GENERATION_MODEL=gpt-5.6-terra
OPENAI_HOOK_SUPPORT_MODEL=gpt-5.6-luna
OPENAI_IMAGE_PROMPT_MODEL=gpt-5.6-terra
OPENAI_CREATIVE_STRATEGY_MODEL=gpt-5.6-luna
OPENROUTER_API_KEY=
OPENROUTER_IMAGE_PROMPT_MODEL=anthropic/claude-sonnet-4.6
# Optional local-only debug bundle. Writes sanitized prompt-agent and GPT Image 2
# JSON logs plus viewable copies of input references and generated outputs.
# API keys, authorization headers, and signed Supabase URLs are never persisted.
ARTWORK_GENERATION_DEBUG_LOG_DIR=
# Keep false during testing. When true, selected hooks and their generated
# Supabase asset locations are stored as brand-scoped learning candidates.
CREATIVE_LEARNING_CAPTURE_ENABLED=false
OPENAI_GUIDELINE_ANALYSIS_MODEL=gpt-5.6-terra
OPENAI_BRAND_LEARNING_MODEL=gpt-5.6-luna
GEMINI_API_KEY=
GEMINI_GROUNDING_MODEL=gemini-3.5-flash
CLIENT_INGESTION_WORKER_TOKEN=
