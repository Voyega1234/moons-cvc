{
  "name": "compass-creative-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:full": "npx --yes vercel@56.4.1 dev --listen 3000",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "references:build": "node ./node_modules/vite-node/vite-node.mjs scripts/build-artwork-reference-catalog.ts",
    "references:upload": "npm run references:build && node --env-file=.env ./node_modules/vite-node/vite-node.mjs scripts/upload-artwork-reference-library.ts",
    "clients:import-mapping": "node --env-file=.env ./node_modules/vite-node/vite-node.mjs scripts/import-active-mapping-clients.ts",
    "worker:client-ingestion": "node --env-file=.env ./node_modules/vite-node/vite-node.mjs scripts/run-client-ingestion-worker.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify:prototype": "node scripts/verify-prototype.mjs",
    "check": "npm run typecheck && npm run test && npm run verify:prototype && npm run build"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/functions": "^3.7.5",
    "google-auth-library": "^10.9.0",
    "jspdf": "^4.2.1",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3"
  }
}
